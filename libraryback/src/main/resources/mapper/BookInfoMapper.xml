<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.BookInfoMapper">

    <resultMap id="BookResultMap" type="com.library.entity.BookInfo">
        <id column="id" property="id"/>
        <result column="isbn" property="isbn"/>
        <result column="title" property="title"/>
        <result column="author" property="author"/>
        <result column="publisher" property="publisher"/>
        <result column="publish_date" property="publishDate"/>
        <result column="category_id" property="categoryId"/>
        <result column="category_name" property="categoryName"/>
        <result column="description" property="description"/>
        <result column="cover_image" property="coverImage"/>
        <result column="price" property="price"/>
        <result column="total_quantity" property="totalQuantity"/>
        <result column="available_quantity" property="availableQuantity"/>
        <result column="location" property="location"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectBookPage" resultMap="BookResultMap">
        SELECT 
            b.id,
            b.isbn,
            b.title,
            b.author,
            b.publisher,
            b.publish_date,
            b.category_id,
            c.name AS category_name,
            b.description,
            b.cover_image,
            b.price,
            b.total_quantity,
            b.available_quantity,
            b.location,
            b.status,
            b.create_time,
            b.update_time
        FROM book_info b
        LEFT JOIN book_category c ON b.category_id = c.id AND c.deleted = 0
        WHERE b.deleted = 0
        <if test="keyword != null and keyword != ''">
            AND (b.title LIKE CONCAT('%', #{keyword}, '%') 
                 OR b.author LIKE CONCAT('%', #{keyword}, '%')
                 OR b.isbn LIKE CONCAT('%', #{keyword}, '%'))
        </if>
        <if test="categoryId != null">
            AND b.category_id = #{categoryId}
        </if>
        ORDER BY b.create_time DESC
    </select>

</mapper>
